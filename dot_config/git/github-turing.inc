# Loaded by ~/.gitconfig via includeIf for clones under:
#   ~/Repositories/github.com/manas-turing/
#   ~/Repositories/github.com/TuringEnterprises/
#   ~/Repositories/github.com/turing-genai-apps/
#   ~/Repositories/github.com/TuringGpt/
#
# Overrides the default Manas73 credential username (set in ~/.gitconfig)
# with manas-turing so the store helper returns the Turing token for
# these clones. credential.<url>.username is a single-value scalar, so
# assigning it here replaces the default cleanly.

[credential "https://github.com"]
	username = manas-turing

[user]
	email = manas.s@turing.com
