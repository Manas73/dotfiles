[user]
	name = Manas Sambare
	email = {{ .email | quote }}
	signingKey = 
[gpg]
	format =
	program = gpg
[commit]
	gpgSign = false
[tag]
	forceSignAnnotated = false
[gpg "ssh"]
	program =
	allowedSignersFile = 
[credential]
	# libsecret-backed credential helper for any residual HTTPS auth
	# (e.g. gh CLI, non-github submodule URLs). Day-to-day GitHub access
	# is via SSH host aliases declared in ~/.ssh/config, so git itself
	# rarely exercises this helper. The Secret Service backend is
	# gnome-keyring-daemon on this machine.
	helper = /usr/lib/git-core/git-credential-libsecret
[ghq]
	root = ~/Repositories
