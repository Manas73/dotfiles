[user]
	name = Manas Sambare
	email = {{ .email | quote }}
	signingKey = 
[gpg]
	format =
	program = gpg
[commit]
	gpgSign = false
[tag]
	forceSignAnnotated = false
[gpg "ssh"]
	program =
	allowedSignersFile = 
[credential]
	helper = store
[ghq]
	root = ~/Repositories

# -- Multi-account credential routing -----------------------------------------
#
# Two GitHub accounts live in ~/.git-credentials: Manas73 (personal) and
# manas-turing (work). The `store` helper returns the first matching
# entry per host, which would otherwise route everything to whichever
# account sorted first.
#
# Fix: tell git which username to use for github.com access based on
# the clone's filesystem path. credential.<url>.username is a
# single-value scalar, so later includes override earlier ones cleanly
# (unlike url.insteadOf, which is multi-valued and ambiguous when two
# bases match the same input).
#
# Individual repo origin URLs stay canonical
# (https://github.com/<owner>/<repo>.git) so repos remain portable.

[credential "https://github.com"]
	username = Manas73

# Turing-specific overrides. Each includeIf points at the same
# github-turing.inc fragment, which overrides credential.username for
# github.com to manas-turing. Later includes win for scalar keys.
#
# Add a new [includeIf] entry below when a new Turing org shows up
# under ~/Repositories/github.com/.

[includeIf "gitdir:~/Repositories/github.com/manas-turing/"]
	path = ~/.config/git/github-turing.inc

[includeIf "gitdir:~/Repositories/github.com/TuringEnterprises/"]
	path = ~/.config/git/github-turing.inc

[includeIf "gitdir:~/Repositories/github.com/turing-genai-apps/"]
	path = ~/.config/git/github-turing.inc

[includeIf "gitdir:~/Repositories/github.com/TuringGpt/"]
	path = ~/.config/git/github-turing.inc
